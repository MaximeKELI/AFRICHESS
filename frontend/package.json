{
  "name": "africhess-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-build} next dev -H 0.0.0.0",
    "build": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-build} next build",
    "build:safe": "NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "lint": "NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-build} next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chess.js": "^1.0.0-beta.8",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "next-intl": "^3.15.0",
    "react": "^18.3.0",
    "react-chessboard": "^4.6.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
