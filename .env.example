# AFRICHESS Environment Variables
# Copy to .env and adjust for your environment

# Django
SECRET_KEY=your-super-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,africhess.com
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
POSTGRES_DB=africhess
POSTGRES_USER=africhess
POSTGRES_PASSWORD=africhess_dev_pg
REDIS_PASSWORD=africhess_redis_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (mot de passe requis en docker-compose local)
REDIS_URL=redis://:africhess_redis_dev@localhost:6379/0
WS_ALLOW_QUERY_TOKEN=false
PREMIUM_DEMO_ALLOWED=false
ALLOW_PUBLIC_API_DOCS=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://africhess.com

# Chess Engine
STOCKFISH_PATH=/usr/games/stockfish
ENGINE_DEPTH=18

# Matchmaking
MATCHMAKING_ELO_RANGE=200

# Stripe (obligatoire en production — pas de mode démo hors DEBUG)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GOLD=
STRIPE_PRICE_DIAMOND=

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# OAuth (optional — voir docs/PREMIUM_OAUTH_SETUP.md)
FRONTEND_URL=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Frontend OAuth toggle (affiche les boutons Google/GitHub)
NEXT_PUBLIC_OAUTH_ENABLED=false
NEXT_PUBLIC_API_ORIGIN=http://localhost:8000
