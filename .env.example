# AFRICHESS Environment Variables
# Copy to .env and adjust for your environment

# Django
SECRET_KEY=your-super-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,africhess.com
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
POSTGRES_DB=africhess
POSTGRES_USER=africhess
POSTGRES_PASSWORD=africhess
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://africhess.com

# Chess Engine
STOCKFISH_PATH=/usr/games/stockfish
ENGINE_DEPTH=18

# Matchmaking
MATCHMAKING_ELO_RANGE=200

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
